{
  "properties": {
    "connectionParameters": {
      "<your-host-name-value>": { //The name of the connection parameter, e.g. "abc.com"
        "type": "string",
        "uiDefinition": {
          "displayName": "host name",
          "description": "The host name of the mcp server, e.g. 'learn.microsoft.com'",
          "tooltip": "Enter the host name of the mcp server, e.g. 'learn.microsoft.com'",
          "constraints": {
            "required": "true"
          }
        }
      }
    },
    "iconBrandColor": "#007ee5",
    "capabilities": [],
    "policyTemplateInstances": [
      {
        "templateId": "dynamichosturl",
        "title": "sethosturl",
        "parameters": {
          "x-ms-apimTemplateParameter.urlTemplate": "https://@connectionParameters('<your-host-name-value>')" //The value of <your-host-name-value> should be the same as the one defined in connectionParameters. For example, if you define "abc.com" in connectionParameters, then the value here should be "https://@connectionParameters('abc.com')"
        }
      }
    ],
    "publisher": "{ publisher name }"
  }
}